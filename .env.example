# Copie para .env e preencha (nunca commite .env)

# Chave privada da conta com tBNB (com ou sem 0x)
PRIVATE_KEY=

# Opcional — padrão já funciona para testnet
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545/

# Mainnet (chain 56) — só para npm run deploy:mainnet
# BSC_MAINNET_RPC=https://bsc-dataseed.binance.org/

# Opcional — chave única em etherscan.io (API v2); serve para BscScan / BSC testnet também
BSCSCAN_API_KEY=

# Obrigatório no deploy — 5 endereços distintos (carteiras registradas no contrato), separados por vírgula
# TEAM_WALLETS=0x...,0x...,0x...,0x...,0x...

# Opcional — 5 rótulos na mesma ordem (evite vírgula no nome); se vazio, fica sem nome no explorer até setWalletName
# TEAM_WALLET_NAMES=Tesouraria,MKT,Dev,Jurídico,Comunidade

# Opcional — única carteira que recebe a taxa em DEVPUL; se vazio, usa o endereço do deploy
# FEE_RECEIVER=0x...

# Opcional — taxa inicial em bps, 0–400 (padrão 400 se omitir)
# INITIAL_FEE_BPS=400

# Opcional — endereço do par PancakeSwap V2 (obtido após criar a pool)
# Se preenchido, o deploy já registra o par automaticamente (setDexPair)
# Se omitido, registrar manualmente depois via BSCScan → Write Contract → setDexPair
# DEX_PAIR_ADDRESS=0x...
